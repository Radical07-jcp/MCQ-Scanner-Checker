<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.sirjpagdi.mcqscanner.CornerSelectView
        android:id="@+id/cornerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <TextView android:id="@+id/tvAlignStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#88000000"
        android:padding="12dp"
        android:textColor="#F2B705"
        android:text="Drag the 4 corners to match the sheet's edges"/>

    <Button android:id="@+id/btnConfirmCorners"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:text="Confirm &amp; Continue"/>

</FrameLayout>
