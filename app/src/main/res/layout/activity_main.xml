<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBackground">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/tnhs_facade"
        android:scaleType="centerCrop"
        android:alpha="0.08"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/tnhs_logo"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tarlac National High School"
                        android:textColor="?attr/appTextPrimary"
                        android:textSize="17sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="?attr/appTextMuted"
                        android:textSize="13sp"/>
                </LinearLayout>

                <TextView android:id="@+id/btnThemeToggle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textColor="?attr/appTextPrimary"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:text="☀"/>
            </LinearLayout>

            <EditText android:id="@+id/etTestName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Test name"
                android:textColorHint="?attr/appTextMuted"
                android:textColor="?attr/appTextPrimary"
                android:layout_marginBottom="16dp"/>

            <EditText android:id="@+id/etQuestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Number of questions"
                android:inputType="number"
                android:textColorHint="?attr/appTextMuted"
                android:textColor="?attr/appTextPrimary"
                android:layout_marginBottom="16dp"/>

            <RadioGroup android:id="@+id/rgChoices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <RadioButton android:id="@+id/rbAD"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="A–D" android:textColor="?attr/appTextPrimary" android:checked="true"/>
                <RadioButton android:id="@+id/rbAE"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="A–E" android:textColor="?attr/appTextPrimary"/>
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paper size per test"
                android:textColor="?attr/appTextMuted"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <RadioGroup android:id="@+id/rgPaperSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">
                <RadioButton android:id="@+id/rbFull"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Full page" android:textColor="?attr/appTextPrimary" android:checked="true"/>
                <RadioButton android:id="@+id/rbHalf"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="½ page" android:textColor="?attr/appTextPrimary"/>
                <RadioButton android:id="@+id/rbQuarter"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="¼ page" android:textColor="?attr/appTextPrimary"/>
            </RadioGroup>

            <TextView android:id="@+id/tvKeyStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No answer key set yet"
                android:textColor="?attr/appTextMuted"
                android:textSize="13sp"
                android:layout_marginBottom="10dp"/>

            <Button android:id="@+id/btnCreateKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CREATE ANSWER KEY HERE"
                android:layout_marginBottom="14dp"/>

            <TextView android:id="@+id/btnScanKeyInstead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SCAN ANSWER KEY INSTEAD"
                android:textColor="?attr/appTextPrimary"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="8dp"
                android:layout_marginBottom="14dp"
                android:background="?attr/selectableItemBackground"/>

            <Button android:id="@+id/btnGeneratePdf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GENERATE &amp; SHARE PDF"
                android:layout_marginBottom="14dp"/>

            <Button android:id="@+id/btnSaveTest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SAVE TEST"
                android:layout_marginBottom="14dp"/>

            <Button android:id="@+id/btnLoadTest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LOAD TEST"
                android:layout_marginBottom="20dp"/>

            <Button android:id="@+id/btnScan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SCAN FILLED SHEETS"
                android:backgroundTint="?attr/appAccent"
                android:textColor="?attr/appAccentText"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <TextView android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="v0.9"
                android:textColor="?attr/appTextMuted"
                android:textSize="13sp"
                android:padding="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/dev_credit"
                android:textColor="?attr/appTextMuted"
                android:textSize="11sp"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
