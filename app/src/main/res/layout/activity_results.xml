<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/appBackground">

    <TextView android:id="@+id/tvScore"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Score: --/--" android:textColor="?attr/appAccent" android:textSize="26sp" android:textStyle="bold"
        android:gravity="center" android:layout_marginBottom="16dp"/>

    <EditText android:id="@+id/etStudentName" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Student name (optional)" android:textColorHint="?attr/appTextMuted" android:textColor="?attr/appTextPrimary"
        android:layout_marginBottom="12dp"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <TextView android:id="@+id/tvDetail"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="?attr/appTextPrimary" android:fontFamily="monospace" android:textSize="13sp"/>
    </ScrollView>

    <Button android:id="@+id/btnExportCsv" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:text="Export CSV"/>

    <Button android:id="@+id/btnScanAnother" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="10dp" android:text="Scan Next Sheet"
        android:backgroundTint="?attr/appAccent" android:textColor="?attr/appAccentText"/>

</LinearLayout>
