<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/chalkboard_green">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Checked Results" android:textColor="@color/chalk_white" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <TextView android:id="@+id/tvHistory"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/chalk_white" android:fontFamily="monospace" android:textSize="13sp"/>
    </ScrollView>

    <Button android:id="@+id/btnExportAll" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:text="Export All to CSV"/>

</LinearLayout>
