<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MCQScanner.Light" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/tnhs_maroon</item>
        <item name="colorAccent">@color/tnhs_gold</item>
        <item name="appBackground">@color/light_bg</item>
        <item name="appSurface">@color/light_surface</item>
        <item name="appTextPrimary">@color/light_text_primary</item>
        <item name="appTextMuted">@color/light_text_muted</item>
        <item name="appAccent">@color/tnhs_maroon</item>
        <item name="appAccentText">@color/light_bg</item>
        <item name="android:windowBackground">@color/light_bg</item>
        <item name="android:textColorPrimary">@color/light_text_primary</item>
        <item name="buttonStyle">@style/TNHSButton.Light</item>
    </style>

    <style name="Theme.MCQScanner.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/tnhs_gold</item>
        <item name="colorAccent">@color/tnhs_gold</item>
        <item name="appBackground">@color/dark_bg</item>
        <item name="appSurface">@color/dark_surface</item>
        <item name="appTextPrimary">@color/dark_text_primary</item>
        <item name="appTextMuted">@color/dark_text_muted</item>
        <item name="appAccent">@color/tnhs_gold</item>
        <item name="appAccentText">@color/dark_bg</item>
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="buttonStyle">@style/TNHSButton.Dark</item>
    </style>

    <style name="Theme.MCQScanner.Black" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/tnhs_gold</item>
        <item name="colorAccent">@color/tnhs_gold</item>
        <item name="appBackground">@color/black_bg</item>
        <item name="appSurface">@color/black_surface</item>
        <item name="appTextPrimary">@color/black_text_primary</item>
        <item name="appTextMuted">@color/black_text_muted</item>
        <item name="appAccent">@color/tnhs_gold</item>
        <item name="appAccentText">@color/black_bg</item>
        <item name="android:windowBackground">@color/black_bg</item>
        <item name="android:textColorPrimary">@color/black_text_primary</item>
        <item name="buttonStyle">@style/TNHSButton.Black</item>
    </style>

    <!-- Default alias so any leftover references to Theme.MCQScanner still resolve -->
    <style name="Theme.MCQScanner" parent="Theme.MCQScanner.Light"/>

    <style name="TNHSButton.Light" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/tnhs_maroon</item>
        <item name="android:textColor">@color/light_bg</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TNHSButton.Dark" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/tnhs_gold</item>
        <item name="android:textColor">@color/dark_bg</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TNHSButton.Black" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/tnhs_gold</item>
        <item name="android:textColor">@color/black_bg</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
